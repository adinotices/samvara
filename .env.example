# ── Copy to .env and fill in. Used by the backend container (docker-compose /
#    fly secrets / your process manager). NEVER commit the filled-in .env. ──

# Auth for the API. "token" requires Authorization: Bearer <token> on every
# request (session token from OTP flow, or static API_TOKEN for cron).
# "none" disables auth (local dev only).
AUTH_MODE=token
# Static token used ONLY by the GitHub Actions cron tick. Not needed in
# config.js — the browser authenticates via the OTP flow instead.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_TOKEN=

# ── Email OTP login ──
# Resend API key (https://resend.com — free tier is sufficient).
RESEND_API_KEY=
# The single email address allowed to log in. Requests for any other address
# are rejected before an OTP is generated.
AUTH_EMAIL=
# From address for login emails. Must be a domain verified in Resend.
EMAIL_FROM=Samvara <noreply@samvara.app>

# Comma-separated exact origin(s) the frontend is served from. Required for the
# browser to call the API cross-origin.
ALLOWED_ORIGINS=https://samvara.app

# ── Beeminder: THIS IS WHAT MOVES REAL MONEY. ──
# Personal auth token from https://www.beeminder.com/api/v1/auth_token.json
BEEMINDER_TOKEN=
# Your Beeminder username (optional but recommended).
BEEMINDER_USER=
# When true, charges go through Beeminder's dryrun flag — the call is made and
# validated but NO money moves. Leave true until you've verified the whole flow
# end to end, then set false to arm real charges.
BEEMINDER_DRYRUN=true

# ── Money safety rails ──
# Reject any charge below this (Beeminder's own floor is $1.00).
MIN_STAKE=1.00
# Hard server-side cap. Any single charge above this is refused, no matter what
# the client sends. Your circuit breaker against a bug or a bad request.
MAX_CHARGE_USD=50.00

# Hours after a deadline before an unanswered rung auto-charges. Keep in sync
# with GRACE_MS in frontend/api-client.js (24h there).
GRACE_HOURS=24

# SQLite path. In Docker this is set to /data/samvara.db (a mounted volume).
SAMVARA_DB=samvara.db
